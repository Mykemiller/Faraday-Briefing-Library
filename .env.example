# ─── Briefing Library Storefront — environment ───────────────────────────────
# Copy to .env.local for local dev; set in Vercel project settings for deploy.

# Supabase (system of record: wallet, cart, entitlements, read-model, preview storage)
NEXT_PUBLIC_SUPABASE_URL=https://ycadmmngkdhvpcsrcuaq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only; never exposed to the client
SUPABASE_STORAGE_BUCKET=library-previews

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Airtable (editorial SOR — synced to the read-model; never in the hot path)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appxfti7VuoHYUeu6
AIRTABLE_BRIEFINGS_TABLE_ID=tbl4kbby85nx6Z891

# Gamma native export API (PNG preview slides → Supabase Storage)
GAMMA_API_KEY=

# Cron / worker shared secret (Vercel cron → API routes)
CRON_SECRET=

# ─── Feature flags (deploy gates — see DEPLOY.md) ────────────────────────────
# All default OFF / preview-only. Flip only when the matching gate clears.
NEXT_PUBLIC_LIBRARY_PREVIEW_ROUTE=true   # storefront lives on the flag-gated preview route
NEXT_PUBLIC_LIBRARY_SUBSCRIBER_LIVE=false # gated by FAR-132 (Gamma theme normalization)
NEXT_PUBLIC_LIBRARY_COMMERCE_ON=false     # gated by FAR-16 (wallet generalization) + FAR-46 (meter)
NEXT_PUBLIC_LIBRARY_ANON_TEASER=true      # 1 teaser slide for anonymous deep links (§4.1, flag-able)
